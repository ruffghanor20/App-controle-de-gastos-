<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.SalaoFinanceiro" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/brand_bg</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.SalaoFinanceiro.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/brand_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_generic</item>
        <item name="postSplashScreenTheme">@style/Theme.SalaoFinanceiro</item>
    </style>
</resources>
